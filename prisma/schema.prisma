datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  price     Float
  tenantId  String   // 预留多租户字段
  createdAt DateTime @default(now())
}